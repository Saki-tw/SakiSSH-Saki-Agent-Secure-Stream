{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Sass": {
    "BindAddress": "127.0.0.1:19284",
    "Shell": {
      "Type": "cmd",
      "Path": "C:\\Windows\\System32\\cmd.exe"
    },
    "ChallengeStore": {
      "TtlSeconds": 60,
      "CleanupIntervalSeconds": 60
    },
    "Tarpit": {
      "TotalBytes": 41943040,
      "ChunkSize": 65536,
      "DelayMs": 500,
      "MaxConcurrent": 32
    },
    "ViSwap": {
      "MaxHoldSeconds": 3600,
      "HeartbeatSeconds": 5
    },
    "Audit": {
      "LogPath": "%USERPROFILE%\\.config\\sass\\audit.jsonl",
      "KeyPath": "%USERPROFILE%\\.config\\sass\\audit_key.bin"
    },
    "Branch": {
      "RootPath": "%TEMP%\\sass_branches"
    },
    "EnvInjector": {
      "VolatileRoot": "%TEMP%\\sass_vol"
    }
  }
}
